# Database Configuration
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=15432
DATABASE_URL=postgresql://id_siber:your_secure_password_here@localhost:15432/id_siber_index

# Meilisearch Configuration
MEILI_MASTER_KEY=your_meilisearch_master_key_here
MEILISEARCH_PORT=7700
MEILISEARCH_URL=http://localhost:7700
MEILI_ENV=development

# Redis Configuration
REDIS_PASSWORD=your_redis_password_here
REDIS_PORT=6379
REDIS_URL=redis://:your_redis_password_here@localhost:6379

# API Configuration
API_HOST=0.0.0.0
API_PORT=8080
RUST_LOG=info

# NLP Service Configuration
NLP_PORT=8081
PYTHONPATH=/app
NLTK_DATA=/app/nltk_data
TRANSFORMERS_CACHE=/app/transformers_cache

# Security
JWT_SECRET=your_jwt_secret_here_minimum_32_characters
API_KEY=your_api_key_here_minimum_32_characters

# External Services
# OpenAI API (for future AI features)
OPENAI_API_KEY=your_openai_api_key_here

# Google Cloud (for future cloud features)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_PROJECT_ID=your_google_project_id

# Monitoring & Observability
SENTRY_DSN=your_sentry_dsn_here
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Development Settings
DEV_MODE=true
DEBUG=false
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# File Upload Settings
MAX_FILE_SIZE=10485760  # 10MB in bytes
UPLOAD_DIR=/tmp/uploads

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_TLS=true

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# Webhook Configuration
WEBHOOK_SECRET=your_webhook_secret_here
WEBHOOK_URL=https://your-webhook-endpoint.com/webhook

# Analytics
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
PLAUSIBLE_API_KEY=your_plausible_api_key
PLAUSIBLE_DOMAIN=https://your-domain.com
